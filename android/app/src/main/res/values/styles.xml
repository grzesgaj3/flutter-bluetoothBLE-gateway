<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window when the process starts before
         Flutter renders its first frame. It is kept fullscreen to avoid a
         flash of white. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Theme applied to the Android Window as Flutter renders its first frame. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
